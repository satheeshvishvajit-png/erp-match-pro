# Copy this file to .env (or export these as real environment variables)
# and restart the app to change its configuration.

# ---- Database --------------------------------------------------------
# Defaults to a local SQLite file if unset. For Postgres:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/erp_match_pro
DATABASE_URL=

# ---- Odoo --------------------------------------------------------------
# mock = uses seeded demo PO/GRN data, no live server needed (default)
# live = connects to a real Odoo instance via XML-RPC
ODOO_MODE=mock
ODOO_URL=https://your-company.odoo.com
ODOO_DB=your-db-name
ODOO_USERNAME=api-user@yourcompany.com
ODOO_API_KEY=your-api-key-or-password

# ---- OCR -----------------------------------------------------------------
# easyocr (default) or regex (skip OCR install, paste text instead)
OCR_ENGINE=easyocr

# ---- Matching ------------------------------------------------------------
PRICE_MATCH_TOLERANCE=0.01
